<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <title>Blech-Optimierungs-Report {{ sheet_metal_id }}</title>
  <style>
    :root {
      --fg: #1f2430;
      --muted: #6b7280;
      --bg: #f8f9fb;
      --card: #ffffff;
      --border: #e5e7eb;
      --high: #d7263d;
      --medium: #f4a62a;
      --low: #39916b;
      --none: #9ca3af;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      color: var(--fg);
      background: var(--bg);
      line-height: 1.5;
    }
    main { max-width: 960px; margin: 0 auto; padding: 32px 24px 64px; }
    header h1 { margin: 0 0 4px; font-size: 24px; font-weight: 600; }
    header .meta { color: var(--muted); font-size: 14px; }
    section { margin-top: 32px; }
    h2 { font-size: 18px; font-weight: 600; margin: 0 0 12px; }
    h3 { font-size: 16px; font-weight: 600; margin: 0 0 6px; }

    .image-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      text-align: center;
    }
    .image-card img {
      max-width: 100%;
      max-height: 480px;
      border-radius: 8px;
    }

    table.overview {
      width: 100%;
      border-collapse: collapse;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    table.overview th, table.overview td {
      text-align: left;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
    }
    table.overview tr:last-child td { border-bottom: none; }
    table.overview th { background: #f1f3f7; font-weight: 600; color: var(--muted); }

    .potential {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      margin-top: 16px;
    }
    .potential-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }
    .potential-header .id { color: var(--muted); font-size: 13px; }

    .subpotential {
      border-top: 1px solid var(--border);
      padding: 16px 0;
    }
    .subpotential:first-of-type { border-top: none; padding-top: 4px; }
    .subpotential-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .subpotential-meta { color: var(--muted); font-size: 12px; }
    .reason { margin: 8px 0 8px; font-size: 14px; }
    .evidence { margin: 0; padding-left: 20px; font-size: 14px; }
    .evidence li { color: var(--fg); }
    .confidence { font-size: 12px; color: var(--muted); margin-top: 8px; }

    .error-box {
      background: #fff2f2;
      border: 1px solid #f3b5b5;
      color: #8d1c1c;
      border-radius: 8px;
      padding: 10px 12px;
      font-size: 13px;
      margin-top: 8px;
    }

    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      color: #fff;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .badge-high { background: var(--high); }
    .badge-medium { background: var(--medium); }
    .badge-low { background: var(--low); }
    .badge-none { background: var(--none); }
  </style>
</head>
<body>
<main>
  <header>
    <h1>Optimierungs-Report · {{ sheet_metal_id }}</h1>
    <div class="meta">Erzeugt am {{ generated_at }}</div>
  </header>

  <section class="image-card">
    <img src="{{ image_data_url }}" alt="Blechkonstruktion {{ sheet_metal_id }}">
  </section>

  <section>
    <h2>Übersicht</h2>
    <table class="overview">
      <thead>
        <tr>
          <th>ID</th>
          <th>Optimierungspotenzial</th>
          <th>Subpotenziale</th>
          <th>Gesamtbewertung</th>
        </tr>
      </thead>
      <tbody>
        {% for p in potentials %}
        <tr>
          <td>{{ p.potential_id }}</td>
          <td>{{ p.potential_name }}</td>
          <td>{{ p.subpotentials | length }}</td>
          <td><span class="badge badge-{{ p.rating.value }}">{{ p.rating.value }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  {% for p in potentials %}
  <section class="potential">
    <div class="potential-header">
      <div>
        <h2>{{ p.potential_name }}</h2>
        <div class="id">{{ p.potential_id }}</div>
      </div>
      <span class="badge badge-{{ p.rating.value }}">{{ p.rating.value }}</span>
    </div>

    {% if p.subpotentials %}
      {% for sp in p.subpotentials %}
      <div class="subpotential">
        <div class="subpotential-header">
          <div>
            <h3>{{ sp.subpotential_name }}</h3>
            <div class="subpotential-meta">
              {{ sp.subpotential_id }}{% if sp.checkpoint_typ %} · {{ sp.checkpoint_typ }}{% endif %}
            </div>
          </div>
          <span class="badge badge-{{ sp.rating.value }}">{{ sp.rating.value }}</span>
        </div>

        {% if sp.error %}
        <div class="error-box"><strong>Fehler:</strong> {{ sp.error }}</div>
        {% else %}
        <p class="reason">{{ sp.reason }}</p>
        {% if sp.evidence %}
        <ul class="evidence">
          {% for e in sp.evidence %}<li>{{ e }}</li>{% endfor %}
        </ul>
        {% endif %}
        <div class="confidence">Confidence: {{ "%.0f" | format(sp.confidence * 100) }}%</div>
        {% endif %}
      </div>
      {% endfor %}
    {% else %}
      <p class="subpotential-meta">Keine Subpotenziale gefunden.</p>
    {% endif %}
  </section>
  {% endfor %}
</main>
</body>
</html>
